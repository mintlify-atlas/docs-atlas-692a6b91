  "keyFeatures": [
    "Interactive farm map with location and field management",
    "Crop and management plan tracking across planting stages",
    "Task management with scheduling, assignment, and completion",
    "Animal inventory and batch tracking",
    "Financial management with expenses, revenue, and reporting",
    "Organic certification workflow and export",
    "Farm insights (biodiversity, soil, labour, prices)",
    "IoT sensor integration and readings",
    "Multi-language support (English, Spanish, Portuguese, French, German, Hindi)",
    "Progressive Web App (PWA) with offline capability"
  ],
